SELECT CreatedById, CreatedDate, CustomOtpDeliveryHandlerId, DoesForgotPasswordRequireAuth, DoesPasswordLoginRequireAuth, DoesPwdlessLoginRequireAuth, DoesRegistrationRequireAuth, HeadlessDiscoveryExecutionUserId, HeadlessDiscoveryHandlerId, Id, IsDeleted, IsFirstPartyAppsAllowed, IsForgotPwdAllowed, IsForgotPwdEmailTemplateAllowlistingEnabled, IsHeadlessUserRegistrationAllowed, IsPwdlessLoginAllowed, IsRecaptchaRequiredForgotPwd, IsRecaptchaRequiredPwdlessLogin, IsRecaptchaRequiredRgstr, IsUniversalClientRgstrAllowed, IsUserDisambiguationAllowedForgotPwd, IsUserDisambiguationAllowedUsernamePwd, LastModifiedById, LastModifiedDate, MaxPasswordResetAttempts, NetworkId, RecaptchaScoreThreshold, RecaptchaSecretKey, RegistrationExecutionUserId, RegistrationHandlerId, RegistrationUserDefaultProfileId, SystemModstamp
  FROM NetworkAuthApiSettings
