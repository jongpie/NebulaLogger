# Copy this file to `.env` (gitignored) and fill in real values to run the
# pipeline locally with nektos/act. See CONTRIBUTING.md for usage details.
#
# Only the npm-only jobs (`code-quality-tests`, `lwc-jest-tests`) can run
# without any secrets. Every scratch-org job requires a real Dev Hub.

# Dev Hub JWT auth — required for any scratch-org job and for the package jobs
DEV_HUB_AUTH_URL=https://login.salesforce.com
DEV_HUB_BOT_USERNAME=
DEV_HUB_CONSUMER_KEY=
# Paste the full PEM contents on a single line, with literal `\n` between lines.
DEV_HUB_JWT_SERVER_KEY=

# Codecov — only used by the base scratch-org job and the LWC Jest job
CODECOV_TOKEN=
