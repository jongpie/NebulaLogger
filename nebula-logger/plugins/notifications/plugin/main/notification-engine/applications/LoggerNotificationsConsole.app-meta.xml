<?xml version="1.0" encoding="UTF-8"?>
<CustomApplication xmlns="http://soap.sforce.com/2006/04/metadata">
    <brand>
        <headerColor>#1E1E1E</headerColor>
        <shouldOverrideOrgTheme>true</shouldOverrideOrgTheme>
    </brand>
    <description>Console app to configure and monitor Nebula Logger notification rules, services, and recipients. Console navigation lets admins keep multiple related records open in workspace tabs.</description>
    <formFactors>Large</formFactors>
    <isNavAutoTempTabsDisabled>false</isNavAutoTempTabsDisabled>
    <isNavPersonalizationDisabled>false</isNavPersonalizationDisabled>
    <isNavTabPersistenceDisabled>false</isNavTabPersistenceDisabled>
    <isOmniPinnedViewEnabled>false</isOmniPinnedViewEnabled>
    <label>Nebula Logger Notifications Console</label>
    <navType>Console</navType>
    <tabs>LoggerNotificationRule__c</tabs>
    <tabs>LoggerNotificationRecipient__c</tabs>
    <tabs>LoggerNotificationService__c</tabs>
    <tabs>LoggerNotificationMatch__c</tabs>
    <tabs>LoggerNotificationDelivery__c</tabs>
    <tabs>standard-WaveHomeLightning</tabs>
    <tabs>standard-Dashboard</tabs>
    <tabs>standard-report</tabs>
    <uiType>Lightning</uiType>
    <workspaceConfig>
        <mappings>
            <fieldName>LoggerNotificationMatch__c</fieldName>
            <tab>LoggerNotificationDelivery__c</tab>
        </mappings>
        <mappings>
            <fieldName>LoggerNotificationRule__c</fieldName>
            <tab>LoggerNotificationMatch__c</tab>
        </mappings>
        <mappings>
            <fieldName>LoggerNotificationRule__c</fieldName>
            <tab>LoggerNotificationRecipient__c</tab>
        </mappings>
        <mappings>
            <tab>LoggerNotificationRule__c</tab>
        </mappings>
        <mappings>
            <tab>LoggerNotificationService__c</tab>
        </mappings>
        <mappings>
            <tab>standard-Dashboard</tab>
        </mappings>
        <mappings>
            <tab>standard-WaveHomeLightning</tab>
        </mappings>
        <mappings>
            <tab>standard-report</tab>
        </mappings>
    </workspaceConfig>
</CustomApplication>
