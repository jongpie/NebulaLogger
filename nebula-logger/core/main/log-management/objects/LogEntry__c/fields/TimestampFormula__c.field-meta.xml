<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TimestampFormula__c</fullName>
    <externalId>false</externalId>
    <formula>TEXT(YEAR(DATEVALUE( FROMUNIXTIME(EpochTimestamp__c / 1000) ))) + &quot;-&quot; +

LPAD(TEXT(MONTH(DATEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 2, &quot;0&quot;) + &quot;-&quot; +

LPAD(TEXT(DAY(DATEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 2, &quot;0&quot;) +  

&quot;T&quot; +

LPAD(TEXT(HOUR(TIMEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 2, &quot;0&quot;) + &quot;:&quot; +

LPAD(TEXT(MINUTE(TIMEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 2, &quot;0&quot;) + &quot;:&quot; +

LPAD(TEXT(SECOND(TIMEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 2, &quot;0&quot;) + &quot;.&quot; +

LPAD(TEXT(MILLISECOND(TIMEVALUE(FROMUNIXTIME(EpochTimestamp__c / 1000)))), 3, &quot;0&quot;) + &quot;Z&quot;</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
